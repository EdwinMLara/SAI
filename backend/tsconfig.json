{
   "extends": "../tsconfig.json",
   "compilerOptions": {
      "outDir": "./dist",
      "rootDir": "../",
   "baseUrl": "./",
      "paths": {
         /* --- base workspaces --- */
         "@common/*": ["../common/*"],
         "@backend/*": ["./src/*"],

         /* --- backend route paths --- */
         "@config/*": ["config/*"],
         "@utils/*": ["utils/*"],
         "@system/*": ["utils/system/*"],

         /* --- common route paths --- */
         "@cmm/interfaces": ["../common/interfaces/index.ts"],
         "@cmm/types/*": ["../common/types/"]
      }
   },
   "include": ["src/**/*", "../common/**/*"],
   "exclude": ["node_modules", "dist", "**/*.test.ts", "**/*.spec.ts"]
}
