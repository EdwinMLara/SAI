{
   "compilerOptions": {
      "target": "es2020",
      "module": "commonjs",
      "rootDir": "../",
      "outDir": "./dist",
      "lib": ["es2020"],
      "types": ["node"],
      "strict": true,
      "esModuleInterop": true,
      "forceConsistentCasingInFileNames": true,
      "skipLibCheck": true,
      "sourceMap": true,
      "noUncheckedIndexedAccess": true,
      "exactOptionalPropertyTypes": true,
      "baseUrl": ".",
      "paths": {
         "@config/*": ["src/config/*"],
         "@controllers/*": ["src/controllers/*"],
         "@cmm_interfaces/*": ["../common/interfaces/*"],
         "@interfaces/*": ["src/interfaces/*"],
         "@middlewares/*": ["src/middlewares/*"],
         "@models/*": ["src/models/*"],
         "@services/*": ["src/services/*"],
         "@utils/*": ["src/utils/*"],
         "@auth/*": ["src/utils/auth/*"],
         "@types": ["src/types/index.ts"],
         "@helpers/*": ["src/helpers/*"],
         "@responses": ["src/utils/responses/index.responses.ts"],
         "@common/*": ["../common/*"]
      }
   },
   "include": ["src", "../common"],
   "exclude": ["node_modules", "dist"]
}
