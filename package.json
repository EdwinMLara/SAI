{
   "name": "sai-monorepo",
   "version": "1.0.0",
   "description": "Sistema de Administración INSOEL - Monorepo",
   "private": true,
   "workspaces": [
      "backend",
      "client"
   ],
   "engines": {
      "node": ">=20.0.0"
   },
   "scripts": {
      "dev": "npm-run-all --parallel dev:backend dev:client",
      "dev:backend": "npm --prefix backend run dev",
      "dev:client": "npm --prefix client run dev",
      "lint": "npm-run-all lint:backend lint:client",
      "lint:fix": "npm-run-all lint:fix:backend lint:fix:client",
      "prettier": "prettier --check .",
      "format": "prettier --write ."
   },
   "devDependencies": {
      "@eslint/js": "^9.27.0",
      "@types/dotenv": "^6.1.1",
      "@typescript-eslint/eslint-plugin": "^8.40.0",
      "@typescript-eslint/parser": "^8.40.0",
      "eslint": "^9.27.0",
      "npm-run-all": "^4.1.5",
      "prettier": "^3.6.2",
      "typescript": "^5.8.3"
   },
   "dependencies": {
      "dotenv": "^16.5.0"
   }
}
