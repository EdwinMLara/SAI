{
   "name": "sai-monorepo",
   "version": "1.0.0",
   "private": true,
   "description": "Sistema de Administración INSOEL",
   "engines": {
      "node": ">=18.0.0",
      "npm": ">=9.0.0"
   },
   "workspaces": [
      "backend",
      "common"
   ],
   "scripts": {
      "dev": "npm run dev --workspace=backend",
      "build": "npm run build --workspaces",
      "lint": "npm run lint --workspaces",
      "format": "prettier --write .",
      "clean": "npm run clean --workspaces",
      "install:all": "npm install --workspaces"
   },
   "devDependencies": {
      "@types/node": "^20.0.0",
      "prettier": "^3.0.0",
      "typescript": "^5.0.0",
      "tsx": "^4.0.0"
   }
}
